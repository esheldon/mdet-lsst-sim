#!/usr/bin/env python

import os


CONDOR_SUBMIT_HEAD = """
universe = vanilla

notification = Never

request_memory = %(mem)s

executable = %(script)s
arguments = "$(FLIST) $(OUTFILE)"

# must be comma separated
transfer_input_files = $(FLIST), %(cut_config)s

# transfer when the job completes
should_transfer_files = YES
when_to_transfer_output = ON_EXIT

getenv = True

kill_sig = SIGINT

environment = "OMP_NUM_THREADS=1"

+experiment = "astro"

+job_name = "%(job_name)s"

"""

SCRIPT = r"""#!/usr/bin/env bash

flist=$1
outfile=$2

cut_config=%(cut_config)s

export OMP_NUM_THREADS=1

mdet-lsst-sim-dosums     \
    --cut-config ${cut_config} \
    --flist ${flist}           \
    --output ${outfile} &> ${outfile}.log
"""


def write_script(script_file, cut_config_file):

    script = SCRIPT % {'cut_config': cut_config_file}

    with open(script_file, 'w') as fobj:
        fobj.write(script)

    os.system(f'chmod 755 {script_file}')


def write_flist(fname, flist):
    with open(fname, 'w') as fobj:
        for fname in flist:
            fobj.write(f'{fname}\n')


def split_flist(flist, nchunks):
    """
    Split the flist in to chunks
    """
    nf = len(flist)
    chunksize = nf // nchunks
    extra_items = nf % nchunks

    flists = []

    start = 0
    for i in range(nchunks):
        this_chunksize = chunksize
        if i <= extra_items:
            this_chunksize += 1

        end = start + this_chunksize

        chunk = flist[start:end]
        flists.append(chunk)

        start = start + this_chunksize

    flists = [flist for flist in flists if len(flist) > 0]
    return flists


def read_flist(fname, limit):

    flist = []
    with open(fname) as fobj:
        for i, line in enumerate(fobj):
            ls = line.strip()
            if ls != '':
                flist.append(ls)

            if limit is not None and (i + 1) == limit:
                break

    return flist


def main(
    flist_file,
    cut_config_file,
    nchunks,
    job_name='sums',
    mem='1G',
    limit=None,
):

    script_file = 'run.sh'
    write_script(script_file, cut_config_file)

    flist = read_flist(fname=flist_file, limit=limit)

    nf = len(flist)

    flists = split_flist(flist, nchunks)
    chunksize = len(flists[0])

    condor_file = 'dosums.condor'
    print(f'processing: {nf}')
    print(f'nchunks: {nchunks}')
    print(f'chunksize: {chunksize}')
    print(f'condor_file: {condor_file}')

    with open(condor_file, 'w') as condorf:
        condor_head = CONDOR_SUBMIT_HEAD % {
            'job_name': job_name,
            'mem': mem,
            'script': script_file,
            'cut_config': cut_config_file,
        }

        condorf.write(condor_head)
        condorf.write('queue FLIST OUTFILE from (\n')

        for ichunk, chunk in enumerate(flists):

            chunk_flist_file = f'flist-{ichunk:06d}.txt'

            write_flist(chunk_flist_file, chunk)

            chunk_file = f'sums-{ichunk:06d}.fits'
            condorf.write(f'{chunk_flist_file} {chunk_file}\n')

        condorf.write(')\n')


def get_args():
    import argparse
    parser = argparse.ArgumentParser()
    parser.add_argument('--flist', required=True)
    parser.add_argument('--cut-config', required=True)
    parser.add_argument('--nchunks', type=int, required=True)
    parser.add_argument('--job-name', default='sums')
    parser.add_argument('--mem', default='1G')
    parser.add_argument('--limit', type=int)
    return parser.parse_args()


if __name__ == '__main__':
    args = get_args()
    main(
        flist_file=args.flist,
        cut_config_file=args.cut_config,
        nchunks=args.nchunks,
        job_name=args.job_name,
        mem=args.mem,
        limit=args.limit,
    )
