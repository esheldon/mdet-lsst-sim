#!/usr/bin/env python

CONDOR_SUBMIT_TEXT = """
universe = vanilla

notification = Never

request_memory = %(mem)s

executable = %(script)s
arguments = "$(FLIST) $(OUTFILE)"

# must be comma separated
transfer_input_files = $(FLIST), %(cut_config)s

# transfer when the job completes
should_transfer_files = YES
when_to_transfer_output = ON_EXIT

getenv = True

kill_sig = SIGINT

environment = "OMP_NUM_THREADS=1"

+experiment = "astro"

+job_name = "%(job_name)s"

# This is a two column, space separated list
queue FLIST OUTFILE from (
%(input_data)s
)
"""

SCRIPT = r"""#!/usr/bin/env bash

flist=$1
outfile=$2

cut_config=%(cut_config)s

export OMP_NUM_THREADS=1

mdet-lsst-sim-dosums     \
    --cut-config ${cut_config} \
    --flist ${flist}           \
    --output ${outfile} &> ${outfile}.log
"""


def write_script(script_file, cut_config_file):
    import os

    script = SCRIPT % {'cut_config': cut_config_file}

    with open(script_file, 'w') as fobj:
        fobj.write(script)

    os.system(f'chmod 755 {script_file}')


def write_chunk_flist(fname, flist):
    with open(fname, 'w') as fobj:
        for fname in flist:
            fobj.write(f'{fname}\n')


def split_flist(flist, nchunks):
    """
    Split the flist in to chunks
    """
    nf = len(flist)
    chunksize = nf // nchunks
    extra_items = nf % nchunks

    flists = []

    start = 0
    for i in range(nchunks):
        this_chunksize = chunksize
        if i <= extra_items:
            this_chunksize += 1

        end = start + this_chunksize

        chunk = flist[start:end]
        flists.append(chunk)

        start = start + this_chunksize

    flists = [flist for flist in flists if len(flist) > 0]
    return flists


def get_flist(directory, limit=None):
    import os

    flist = []
    for root, dirs, files in os.walk(directory, topdown=False):
        for basename in files:
            if (
                '.fits' in basename
                and basename[:4] != 'sums'
                and 'mc-results' not in root
            ):
                fname = os.path.join(root, basename)
                fname = os.path.abspath(fname)
                flist.append(fname)

    nf = len(flist)
    if nf == 0:
        raise RuntimeError('no files found')

    if limit is not None:
        flist = flist[:limit]

    return flist


def main(
    directory,
    job_name,
    nchunks,
    cut_config_file,
    limit,
    mem,
):
    import os

    script_file = 'run.sh'
    write_script(script_file, cut_config_file)

    flist = get_flist(directory=directory, limit=limit)
    nf = len(flist)

    flists = split_flist(flist, nchunks)
    chunksize = len(flists[0])

    condor_file = 'dosums.condor'
    print(f'processing: {nf}')
    print(f'nchunks: {nchunks}')
    print(f'chunksize: {chunksize}')
    print(f'condor_file: {condor_file}')

    dlist = []

    for ichunk, chunk in enumerate(flists):

        chunk_flist_file = f'flist-{ichunk:06d}.txt'

        write_chunk_flist(chunk_flist_file, chunk)

        # we use the basename because it is expected we run the condor
        # script for that directory
        chunk_file = f'sums-{ichunk:06d}.fits'
        chunk_file_base = os.path.basename(chunk_file)
        chunk_flist_file_base = os.path.basename(chunk_flist_file)

        line = f'{chunk_flist_file_base} {chunk_file_base}'
        dlist.append(line)

    input_data = '\n'.join(dlist)

    condor_text = CONDOR_SUBMIT_TEXT % {
        'job_name': job_name,
        'mem': mem,
        'script': script_file,
        'input_data': input_data,
        'cut_config': cut_config_file,
    }

    with open(condor_file, 'w') as condor_fobj:
        condor_fobj.write(condor_text)


def get_args():
    import argparse
    parser = argparse.ArgumentParser()
    parser.add_argument('--directory', required=True)
    parser.add_argument('--cut-config', required=True)
    parser.add_argument('--nchunks', type=int, required=True)
    parser.add_argument('--job-name', default='sums')
    parser.add_argument('--limit', type=int)
    parser.add_argument('--mem', default='1G')
    return parser.parse_args()


if __name__ == '__main__':
    args = get_args()
    main(
        directory=args.directory,
        job_name=args.job_name,
        nchunks=args.nchunks,
        cut_config_file=args.cut_config,
        limit=args.limit,
        mem=args.mem,
    )
