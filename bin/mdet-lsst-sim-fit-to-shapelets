#!/usr/bin/env python

SCALE = 0.2


def get_obs(image):
    import numpy as np
    import ngmix

    cen = (np.array(image.shape) - 1.0) / 2.0
    jac = ngmix.DiagonalJacobian(
        row=cen[0],
        col=cen[1],
        scale=SCALE,
    )
    return ngmix.Observation(
        image=image,
        jacobian=jac,
    )


def do_em(obs, rng, ngauss, show=False):
    import ngmix
    obs_with_sky, sky = ngmix.em.prep_obs(obs)

    fitter = ngmix.em.EMFitter(maxiter=5000)
    guesser = ngmix.guessers.GMixPSFGuesser(
        rng=rng,
        ngauss=ngauss,
        guess_from_moms=True,
    )

    for itrial in range(10):
        guess = guesser(obs_with_sky)
        res = fitter.go(obs=obs_with_sky, guess=guess, sky=sky)
        if res['flags'] == 0:
            break

    if res['flags'] != 0:
        raise RuntimeError(f'failed {res["message"]}')

    gm = res.get_gmix()

    if show:
        import espy.images
        model = gm.make_image(obs.image.shape, jacobian=obs.jacobian)
        espy.images.compare_images(
            obs.image,
            model,
            nonlinear=0.01 * model.max(),
        )

    return gm


def main(infile, outfile, seed, nrand, ngauss, show):
    import numpy as np
    import mdet_lsst_sim
    import galsim
    import fitsio
    from tqdm import trange

    rng = np.random.RandomState(seed)

    shlib = mdet_lsst_sim.shapelet_psf.ShapeletPSFLibrary(
        npz_path=infile,
        rng=rng,
        rotate=True,
        max_nongauss_frac=0.005,
        nmax=15,
    )

    shpsf = mdet_lsst_sim.shapelet_psf.ShapeletPSF(shlib=shlib)

    pos_ = galsim.PositionD(0.2, 0.5)

    pars = np.zeros((nrand, 6 * ngauss))

    for i in trange(nrand, ascii=True, ncols=70):
        psf = shpsf.getPSF(pos_)
        image = shpsf.shlib.draw(
            psf,
            n=51,
            pixel_scale=SCALE,
        ).array

        obs = get_obs(image)

        gm = do_em(obs, rng, ngauss, show=show)

        pars[i] = gm.get_full_pars()

    print('writing:', outfile)
    fitsio.write(outfile, pars, clobber=True)


def get_args():
    import argparse

    parser = argparse.ArgumentParser()
    parser.add_argument('--infile', required=True, help='shapelets file')
    parser.add_argument('--outfile', required=True, help='output file')
    parser.add_argument('--seed', type=int)
    parser.add_argument('--nrand', type=int, default=10000)
    parser.add_argument('--ngauss', type=int, default=5)
    parser.add_argument('--show', action='store_true')

    return parser.parse_args()


if __name__ == '__main__':
    args = get_args()
    main(
        infile=args.infile,
        outfile=args.outfile,
        seed=args.seed,
        nrand=args.nrand,
        ngauss=args.ngauss,
        show=args.show,
    )
