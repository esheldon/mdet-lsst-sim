#!/usr/bin/env python
import numpy as np
from numba import njit

SCALE = 0.2
EM_FIT_FAILED = 2**1
TURB_FIT_FAILED = 2**2


def get_obs(image):
    import numpy as np
    import ngmix

    noise = get_edge_std(image, 4, 4)

    cen = (np.array(image.shape) - 1.0) / 2.0
    jac = ngmix.DiagonalJacobian(
        row=cen[0],
        col=cen[1],
        scale=SCALE,
    )
    return ngmix.Observation(
        image=image,
        weight=image * 0 + 1.0 / noise ** 2,
        jacobian=jac,
    )


def plot_with_colorbar(fig, ax, image, title=None, **kw):
    from mpl_toolkits.axes_grid1 import make_axes_locatable

    pim = ax.imshow(image, **kw)

    divider = make_axes_locatable(ax)
    cax = divider.append_axes("right", size="5%", pad=0.05)
    fig.colorbar(pim, cax=cax)

    if title is not None:
        ax.set_title(title)


def dotext(ax, x, y, text):
    ax.text(
        x,
        y,
        text,
        transform=ax.transAxes,
        color='black',
    )
    ax.text(
        x + 0.002,
        y + 0.002,
        text,
        transform=ax.transAxes,
        color='white',
    )


@njit
def get_edge_std(im, nsig, npass):
    mean = -9999.0
    sigma = -9999.0
    for ipass in range(npass):
        xsum = 0.0
        x2sum = 0.0

        nrow, ncol = im.shape

        nsum = 0
        for icol in range(ncol):
            val = im[0, icol]
            if _check_keep(val, mean, sigma, nsig, ipass):
                xsum += val
                x2sum += val**2
                nsum += 1

            val = im[-1, icol]
            if _check_keep(val, mean, sigma, nsig, ipass):
                xsum += val
                x2sum += val**2
                nsum += 1

        for irow in range(nrow):
            val = im[irow, 0]
            if _check_keep(val, mean, sigma, nsig, ipass):
                xsum += val
                x2sum += val**2
                nsum += 1

            val = im[irow, -1]
            if _check_keep(val, mean, sigma, nsig, ipass):
                xsum += val
                x2sum += val**2
                nsum += 1

        mean = xsum / nsum
        var = x2sum / nsum - mean**2
        sigma = np.sqrt(var)

    return sigma


@njit
def _check_keep(val, mean, sigma, nsig, ipass):
    keep = True
    if ipass > 0:
        if abs(val - mean) > nsig * sigma:
            keep = False

    return keep


def doshow(image, model, data, index, name):
    import matplotlib.pyplot as mplt
    from matplotlib.colors import AsinhNorm

    cmap = mplt.colormaps.get_cmap('inferno')

    noise = get_edge_std(image, 4, 4)

    norm = AsinhNorm(
        linear_width=noise,
        clip=False,
    )

    stat = data['stat']

    maxval = 1.0
    image_mod = image.copy()

    with mplt.style.context('dark_background'):
        fig, axs = mplt.subplots(
            nrows=2,
            ncols=2,
            figsize=(10, 9),
        )
        axs[1, 1].axis('off')

        plot_with_colorbar(
            fig=fig,
            ax=axs[0, 0],
            image=image_mod / maxval,
            cmap=cmap,
            norm=norm,
            title=f'image {index}',
        )

        dotext(axs[0, 0], 0.1, 0.9, f'stat: {stat:.4g}')

        plot_with_colorbar(
            fig=fig,
            ax=axs[0, 1],
            image=model / maxval,
            cmap=cmap,
            norm=norm,
            title=name,
        )

        plot_with_colorbar(
            fig=fig,
            ax=axs[1, 0],
            image=(image - model) / maxval,
            cmap=cmap,
            title='image - gmix5',
        )
        if True:
            fname = [
                f'{data["raft"]}',
                f'{data["detector"]:03d}',
                f'{index:04d}',
                f'{name}',
            ]
            fname = '-'.join(fname) + '.png'
            fname = f'plots/{fname}'
            print('writing:', fname)
            fig.savefig(fname)
        else:
            mplt.show()

        mplt.close(fig)


def get_turb_prior(rng, scale=0.2, T_range=None, F_range=None):
    """
    get a prior for use with the maximum likelihood fitter

    Parameters
    ----------
    rng: np.random.RandomState
        The random number generator
    scale: float
        Pixel scale
    T_range: (float, float), optional
        The range for the prior on T
    F_range: (float, float), optional
        Fhe range for the prior on flux
    """
    import ngmix

    if T_range is None:
        T_range = [-1.0, 1.0e3]

    if F_range is None:
        F_range = [-100.0, 1.0e9]

    g_prior = ngmix.priors.GPriorBA(sigma=0.1, rng=rng)
    cen_prior = ngmix.priors.CenPrior(
        cen1=0,
        cen2=0,
        sigma1=scale,
        sigma2=scale,
        rng=rng,
    )
    T_prior = ngmix.priors.FlatPrior(
        minval=T_range[0], maxval=T_range[1], rng=rng
    )
    F_prior = ngmix.priors.FlatPrior(
        minval=F_range[0], maxval=F_range[1], rng=rng
    )

    prior = ngmix.joint_prior.PriorSimpleSep(
        cen_prior=cen_prior,
        g_prior=g_prior,
        T_prior=T_prior,
        F_prior=F_prior,
    )

    return prior


def do_turb(obs, rng):
    import ngmix

    prior = get_turb_prior(rng=rng)

    fitter = ngmix.fitting.Fitter(model='turb', prior=prior)

    guesser = ngmix.guessers.SimplePSFGuesser(
        rng=rng,
        guess_from_moms=True,
    )

    runner = ngmix.runners.PSFRunner(
        fitter=fitter,
        guesser=guesser,
        ntry=10,
    )
    res = runner.go(obs)

    if res['flags'] != 0:
        print(f'turb failed {res["message"]}')
        gm = None
        fit_flags = TURB_FIT_FAILED
    else:
        gm = res.get_gmix()
        fit_flags = 0

    return gm, fit_flags


def do_em(obs, rng, ngauss):
    import ngmix

    obs_with_sky, sky = ngmix.em.prep_obs(obs)

    fitter = ngmix.em.EMFitter(maxiter=5000)
    guesser = ngmix.guessers.GMixPSFGuesser(
        rng=rng,
        ngauss=ngauss,
        guess_from_moms=True,
    )

    for itrial in range(10):
        guess = guesser(obs_with_sky)
        res = fitter.go(obs=obs_with_sky, guess=guess, sky=sky)
        if res['flags'] == 0:
            break

    if res['flags'] != 0:
        print(f'failed {res["message"]}')
        gm = None
        fit_flags = EM_FIT_FAILED
    else:
        gm = res.get_gmix()
        fit_flags = 0

    return gm, fit_flags


def make_output(ngauss, stamp_data, index, n=1):
    import numpy as np

    descr = [
        ('flags', 'i4'),
        ('cx', 'f4'),
        ('cy', 'f4'),
        ('detector', 'i4'),
        ('raft', 'U3'),
        ('visit', 'i8'),
        ('band', 'U1'),
        ('n_stack', 'i4'),
        ('pars', 'f4', 6 * ngauss),
        ('stat', 'f4'),
        ('turb_flags', 'i4'),
        ('turb_pars', 'i4'),
    ]

    output = np.zeros(n, dtype=descr)

    for name in stamp_data.keys():
        if name == 'band':
            continue

        if name in output.dtype.names:
            output[name] = stamp_data[name][index]

    output['band'] = stamp_data['band']
    output['pars'] = np.nan
    output['stat'] = np.nan
    return output


def get_stat_old(gm):
    gmdata = gm.get_data()

    row, col = gm.get_cen()

    rowdiff = gmdata['row'] - row
    coldiff = gmdata['col'] - col

    p = gmdata['p']
    ipsum = 1.0 / p.sum()

    irr = ((gmdata['irr'] + rowdiff**2) * p).sum() * ipsum
    icc = ((gmdata['icc'] + coldiff**2) * p).sum() * ipsum

    irrf = (gmdata['irr'] * p).sum() * ipsum
    iccf = (gmdata['icc'] * p).sum() * ipsum

    T = irr + icc
    Tf = irrf + iccf

    stat = T / Tf

    return stat


def get_stat(image, model, turb_model):

    model_chi2 = ((model - image) ** 2).sum()
    turb_chi2 = ((turb_model - image) ** 2).sum()

    stat = turb_chi2 / model_chi2 - 1.0
    return stat


def process_one(rng, stamp_data, index, ngauss, show):
    import numpy as np

    darray = make_output(ngauss, stamp_data, index)

    data = darray[0]

    image = stamp_data['stamps'][index]

    obs = get_obs(image)

    gm, fit_flags = do_em(obs=obs, rng=rng, ngauss=ngauss)
    data['flags'] |= fit_flags

    turb_gm, turb_fit_flags = do_turb(obs=obs, rng=rng)
    data['flags'] |= turb_fit_flags

    if data['flags'] == 0:
        model = gm.make_image(obs.image.shape, jacobian=obs.jacobian)
        assert np.all(model > 0.0)

        turb_model = turb_gm.make_image(obs.image.shape, jacobian=obs.jacobian)

        data['stat'] = get_stat(
            image=image, model=model, turb_model=turb_model
        )
        data['pars'] = gm.get_full_pars()

        assert np.all(darray['pars'][0] == data['pars'])

        if show:
            doshow(
                image=obs.image,
                model=model,
                data=data,
                index=index,
                name=f'gmix{ngauss}',
            )
            doshow(
                image=obs.image,
                model=turb_model,
                data=data,
                index=index,
                name='turb',
            )

    return darray


def make_meta(seed, ngauss):
    import numpy as np

    dtype = [
        ('seed', 'i8'),
        ('ngauss', 'i4'),
    ]
    meta = np.zeros(1, dtype=dtype)
    meta['seed'] = seed
    meta['ngauss'] = ngauss
    return meta


def get_flist(fname):
    with open(fname) as fobj:
        lines = [line.strip() for line in fobj]

    return lines


def main(flist_file, outfile, seed, ngauss, show):
    import numpy as np
    import fitsio
    from tqdm import tqdm

    flist = get_flist(flist_file)

    rng = np.random.RandomState(seed)

    dlist = []

    for infile in tqdm(flist, ascii=True, ncols=70):
        # print('loading:', infile)
        stamp_data = np.load(infile)

        for i in range(stamp_data['cx'].size):
            data = process_one(
                rng=rng,
                stamp_data=stamp_data,
                index=i,
                ngauss=ngauss,
                show=show,
            )
            dlist.append(data)

    output = np.concatenate(dlist)

    meta = make_meta(
        seed=seed,
        ngauss=ngauss,
    )

    print('writing:', outfile)
    with fitsio.FITS(outfile, 'rw', clobber=True) as fits:
        fits.write(output, extname='fits')
        fits.write(meta, extname='meta')


def get_args():
    import argparse

    parser = argparse.ArgumentParser()
    parser.add_argument(
        '--flist',
        help='file with list of stamps files',
        required=True,
    )
    parser.add_argument('--outfile', required=True, help='output file')
    parser.add_argument('--seed', type=int, required=True)
    parser.add_argument('--ngauss', type=int, default=5)
    parser.add_argument('--show', action='store_true')

    return parser.parse_args()


if __name__ == '__main__':
    args = get_args()
    main(
        flist_file=args.flist,
        outfile=args.outfile,
        seed=args.seed,
        ngauss=args.ngauss,
        show=args.show,
    )
